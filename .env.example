# Create a local .env.local file with these values before enabling career-email delivery.
# RESEND_FROM_EMAIL must use a domain verified in your Resend account.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Grey Promos Careers <careers@your-verified-domain.com>
CAREERS_RECIPIENT_EMAIL=careers@greypromos.com
